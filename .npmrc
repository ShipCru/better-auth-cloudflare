# Dedupe peer-deps so workspace consumers (examples/*) and the package
# under test share the same `better-auth` instance. Without this, pnpm
# creates separate copies of `better-auth` for the package and for each
# consumer — same version on disk, but TypeScript treats the types as
# unrelated, forcing `any` casts at adapter boundaries.
#
# See https://pnpm.io/npmrc#dedupe-peer-dependents
dedupe-peer-dependents=true
auto-install-peers=true
